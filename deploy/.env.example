# Copy to deploy/.env and edit. deploy.sh / docker-compose read this.

# --- Postgres (bundled db service) ---
POSTGRES_DB=salesforecast
POSTGRES_USER=sf_user
POSTGRES_PASSWORD=change-me-please

# --- Forecasting backend ---
# seasonal = zero-dependency baseline (default, no GPU).
# chronos  = real Chronos-2 (needs requirements-forecast.txt + GPU + toolkit).
SF_FORECAST_BACKEND=seasonal
SF_CHRONOS_DEVICE=cpu            # e.g. cuda:0 (A2, avoids traderific's live idx 1) when backend=chronos
SF_FORECAST_HORIZON=14

# --- Anomaly / inventory tuning (optional overrides) ---
# SF_ANOMALY_LOOKBACK=45
# SF_INVENTORY_VARIANCE_PCT=0.20
# SF_PAR_WEEKS=1.5

# --- MCP ---
# Bearer token clients must present (Authorization: Bearer <token>). Leave blank to disable auth.
SF_MCP_TOKEN=
