# KFC store-node health agent — copy to /etc/sales-forecast-agent.env and edit.
# Only SF_STORE (and SF_NODE_TOKEN if the server sets one) is strictly required.

SF_API=http://192.168.50.85:8900
SF_STORE=KFC-HCM01
SF_NODE_TOKEN=                 # must equal the server's SF_NODE_TOKEN (blank = no token)
SF_AGENT_INTERVAL=30          # seconds between report+poll cycles
SF_AGENT_EXECUTE=0            # 0 = DRY-RUN (safe: logs what it would run). Set 1 to actually execute.
SF_AGENT_GATEWAY=8.8.8.8      # host to ping for the network probe
SF_AGENT_FAILED_LOGIN_CRIT=8  # failed-login count that trips a security-critical (intrusion) alert

# systemd units this node actually runs (blank = "not monitored on this node")
SF_UNIT_POS=pos.service
SF_UNIT_KDS=
SF_UNIT_PRINTER=cups.service
SF_UNIT_PAYMENT=
SF_UNIT_BACKUP=

# Environment-specific remediation commands (space-separated argv; blank = action unsupported).
# The built-in restart_* actions default to `systemctl restart <unit>`; these cover the rest.
SF_CMD_FAILOVER_LTE=          # e.g. /usr/local/bin/failover-lte.sh
SF_CMD_RESTART_ROUTER=        # e.g. /usr/local/bin/restart-router.sh
SF_CMD_SYNC=                  # e.g. /usr/local/bin/run-db-sync.sh
SF_CMD_CLEAR_TEMP=            # e.g. /usr/bin/find /var/tmp/pos -type f -delete
SF_CMD_FORCE_LOGOUT=          # e.g. /usr/local/bin/force-logout.sh
SF_CMD_ROTATE_CREDS=          # e.g. /usr/local/bin/rotate-creds.sh
SF_CMD_REBOOT_TERMINAL=       # e.g. /usr/local/bin/reboot-terminal.sh
# block_ip is built in: iptables -A INPUT -s <detected-ip> -j DROP  (needs root/CAP_NET_ADMIN)
